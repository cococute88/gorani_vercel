NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Phase C — Firestore Read Adapter feature flag.
# OFF (default): Portfolio Manager keeps its existing data path (localStorage + legacy raw snapshot sync).
# ON: Portfolio Manager sources data ONLY through the Firestore contract read adapter (read-only).
NEXT_PUBLIC_USE_FIRESTORE_CONTRACT=false

# --- Server-side Firestore (Admin SDK) — portfolio_snapshots read layer ---
# Service account JSON for the Firebase Admin SDK. SERVER ONLY (no NEXT_PUBLIC_ prefix),
# so it is never exposed to the browser. Used by lib/firestore/* to read the
# top-level `portfolio_snapshots` collection written by bs-report-auto.
#
# Value: the full service account JSON. It may be provided either as:
#   - the raw JSON string (single line), or
#   - a base64-encoded JSON string (recommended for .env / hosting dashboards).
# Example (raw): FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...",...}
FIREBASE_SERVICE_ACCOUNT_KEY=
