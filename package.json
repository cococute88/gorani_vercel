  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.12.7",
    "lucide-react": "0.408.0",
    "xlsx": "0.18.5",
    "firebase": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "5.5.3",
    "@types/node": "20.14.10",
