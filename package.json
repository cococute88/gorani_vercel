    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:portfolio-realdata": "node scripts/check-portfolio-realdata.mjs",
    "check:portfolio-ux-rules": "node scripts/check-portfolio-ux-rules.mjs",
    "check:performance-ranking-filters": "node scripts/check-performance-ranking-filters.mjs",
    "check:krx-ticker-name-map": "node scripts/check-krx-ticker-name-map.mjs",
    "check:performance-snapshots": "node scripts/check-performance-snapshots.mjs",
    "check:performance-qld-snapshots": "node scripts/check-performance-qld-snapshots.mjs",
    "check:portfolio-parser": "node scripts/check-portfolio-parser.mjs",
    "check:portfolio-parser:private": "node scripts/check-portfolio-parser.mjs --private docs/fixtures/portfolio-parser/private/2025-06-12~2026-06-12.xlsx",
    "check:calendar-provider": "node scripts/check-calendar-provider.mjs",
    "check:calendar-ux-rules": "node scripts/check-calendar-ux-rules.mjs",
    "check:legacy-calendar-import": "node scripts/check-legacy-calendar-import.mjs",
    "check:tax-saving": "node scripts/check-tax-saving-calculator.mjs",
